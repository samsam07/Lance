# Lance — EditorConfig
# Mechanical conventions triaged out of CONVENTIONS.md.
# Judgment rules live in CONVENTIONS.md; machine-checkable rules live here.

root = true

[*]
indent_style = space
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4

# File-scoped namespaces
csharp_style_namespace_declarations = file_scoped:warning

# using directives: System first, blank line between groups
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# Private field naming: _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

# Private const fields: PascalCase (more specific than the field rule above — takes priority for const)
dotnet_naming_rule.private_const_pascal.severity = warning
dotnet_naming_rule.private_const_pascal.symbols = private_const_fields
dotnet_naming_rule.private_const_pascal.style = pascal_case_style

dotnet_naming_symbols.private_const_fields.applicable_kinds = field
dotnet_naming_symbols.private_const_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_const_fields.required_modifiers = const

dotnet_naming_style.pascal_case_style.capitalization = pascal_case
